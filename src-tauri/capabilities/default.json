{
  "identifier": "default",
  "description": "Default permissions for Ether",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:read-all",
    {
      "identifier": "fs:scope",
      "allow": [{"path": "**"}]
    }
  ]
}
